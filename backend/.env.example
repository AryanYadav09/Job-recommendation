NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/smart_job_reco
JWT_SECRET=replace-with-a-strong-secret
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173

# OCR settings
OCR_LANGUAGE=eng
# Optional: point to locally cached Tesseract traineddata files if your server
# cannot download them on first OCR run.
TESSERACT_LANG_PATH=

# Optional registry validation provider
# Supported value: opencorporates
COMPANY_REGISTRY_PROVIDER=
OPENCORPORATES_API_TOKEN=
